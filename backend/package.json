{
  "name": "agentic-ai-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Agentic AI Platform",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "seed:reset": "npx prisma migrate reset --force && ts-node prisma/seed.ts",
    "reseed": "ts-node scripts/reseed.ts",
    "load-test": "ts-node scripts/load-test.ts",
    "demo-data": "ts-node scripts/demo-data.ts",
    "audit": "ts-node scripts/audit-tests.ts",
    "check-auth": "ts-node scripts/check-auth.ts",
    "fix-providers": "ts-node scripts/fix-agent-providers.ts"
  },
